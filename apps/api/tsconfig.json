{
  "extends": "@repo/typescript-config/node.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node",

    // We don't need these for our final build
    "declarationMap": false,
    "declaration": false,
    "sourceMap": false,
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"],
  "ts-node": {
    "swc": true
  }
}
